{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Backend: Start Server",
			"type": "shell",
			"command": "npm",
			"args": [
				"start"
			],
			"options": {
				"cwd": "${workspaceFolder}/backend"
			},
			"isBackground": true,
			"problemMatcher": [],
			"group": {
				"kind": "build",
				"isDefault": false
			}
		},
		{
			"label": "Frontend: Start Dev Server",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"dev"
			],
			"options": {
				"cwd": "${workspaceFolder}/frontend"
			},
			"isBackground": true,
			"problemMatcher": [],
			"group": {
				"kind": "build",
				"isDefault": false
			}
		},
		{
			"label": "Install Dependencies",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-Command",
				"Push-Location '${workspaceFolder}/backend'; npm install; Pop-Location; Push-Location '${workspaceFolder}/frontend'; npm install; Pop-Location; Write-Host 'Dependencies installed successfully'"
			],
			"isBackground": false,
			"problemMatcher": [],
			"group": {
				"kind": "build",
				"isDefault": false
			}
		}
	]
}